{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/", "destination": "/projects/bpo/DARION-BPO-2026-001/login", "permanent": false },
    { "source": "/projects/bpo/DARION-BPO-2026-001", "destination": "/projects/bpo/DARION-BPO-2026-001/login", "permanent": false }
  ],
  "headers": [
    {
      "source": "/projects/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    },
    {
      "source": "/projects/(.*)/admin(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" },
        { "key": "Cache-Control", "value": "no-store, no-cache" },
        { "key": "Pragma", "value": "no-cache" }
      ]
    },
    {
      "source": "/projects/(.*)\\.css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/projects/(.*)\\.js",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ]
}
